# Required. Railway PostgreSQL provides this automatically when the app service
# is connected to a Postgres database service. For local dev, use a local
# PostgreSQL URL such as postgresql://postgres:postgres@localhost:5432/aegis.
DATABASE_URL=postgresql://user:password@host:5432/aegis

# Preferred. Separate multiple provider tokens with commas, spaces, or semicolons.
HF_TOKENS=hf_your_first_token_here,hf_your_second_token_here

# Backward-compatible single-token fallback. Used after HF_TOKENS if both are set.
# HF_TOKEN=hf_your_token_here

# Optional. Override the provider model ID used behind the sheepstealer UI label.
# HF_MODEL_ID=provider/model-id

# Optional experimental local bridge.
# Keep the default "hf" for the current hosted sheepstealer flow.
# Use "local_bridge" to make /api/analyze enqueue synthesis jobs for local_llm_worker.py.
# Use "codex_direct" to bypass the passive backend collector and pass only the target to Codex.
# AEGIS_ANALYSIS_MODE=codex_direct
# AEGIS_LLM_PROVIDER=local_bridge
# AEGIS_LOCAL_BRIDGE_TIMEOUT_SECONDS=1800
#
# Worker options for local_llm_worker.py:
# AEGIS_LOCAL_WORKER_PROVIDER=codex
# AEGIS_CODEX_COMMAND=.aegis-codex-cli\node_modules\.bin\codex.cmd
# AEGIS_CODEX_ARGS=--ask-for-approval never exec --sandbox read-only --ephemeral -c model=gpt-5.5 -c model_reasoning_effort=xhigh -C {workspace} --output-last-message {output_file} -
# AEGIS_CODEX_PROMPT_MODE=stdin
# AEGIS_CODEX_TIMEOUT_SECONDS=1800
#
# Alternative worker mode:
# AEGIS_LOCAL_WORKER_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional. Enables "Continue with Google" in the login screen.
# Create a Web OAuth Client ID in Google Cloud and add the current origin
# such as http://127.0.0.1:8000 to Authorized JavaScript origins.
# GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Admin tester. Defaults in code are caraxes88/caraxes88 for the requested launch tester.
# Override these in Railway when rotating the admin credentials.
# AEGIS_ADMIN_USERNAME=caraxes88
# AEGIS_ADMIN_PASSWORD=caraxes88

# Optional. Keep disabled for public deployments to reduce SSRF risk.
# Set to true only for local lab targets such as localhost or private ranges.
AEGIS_ALLOW_PRIVATE_TARGETS=false
