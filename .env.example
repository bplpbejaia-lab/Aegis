# Preferred. Separate multiple provider tokens with commas, spaces, or semicolons.
HF_TOKENS=hf_your_first_token_here,hf_your_second_token_here

# Backward-compatible single-token fallback. Used after HF_TOKENS if both are set.
# HF_TOKEN=hf_your_token_here

# Optional. Override the provider model ID used behind the Opus 4.8 UI label.
# HF_MODEL_ID=provider/model-id

# Optional experimental local bridge.
# Keep the default "hf" for the current hosted/Kimi flow.
# Use "local_bridge" to make /api/analyze enqueue synthesis jobs for local_llm_worker.py.
# AEGIS_LLM_PROVIDER=local_bridge
# AEGIS_LOCAL_BRIDGE_TIMEOUT_SECONDS=900
#
# Worker options for local_llm_worker.py:
# AEGIS_LOCAL_WORKER_PROVIDER=codex
# AEGIS_CODEX_COMMAND=codex
# AEGIS_CODEX_ARGS=exec
# AEGIS_CODEX_PROMPT_MODE=stdin
#
# Alternative worker mode:
# AEGIS_LOCAL_WORKER_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional. Keep disabled for public deployments to reduce SSRF risk.
# Set to true only for local lab targets such as localhost or private ranges.
AEGIS_ALLOW_PRIVATE_TARGETS=false
